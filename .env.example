# MedBridge Configuration
# Copy this file to .env and adjust values as needed

# Data cleaning
ANCHOR_YEAR=38
ANCHOR_CHARTTIME=2024-05-18

# Application
APP_NAME=MedBridge
DEBUG=False
ENVIRONMENT=development

# Data paths
DATA_INPUT_DIR=data/input
DATA_EVAL_DIR=data/eval
DISCHARGE_CSV=data/input/Sample1_Charts_Updated.csv
PHARMACY_CSV=data/input/Sample1_Rx_Updated.csv

# Redis (Memory layer)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=True

# Redis TTL settings (in seconds)
REDIS_TTL_SHORT_TERM=604800      # 7 days
REDIS_TTL_LONG_TERM=7776000      # 90 days
REDIS_TTL_RUN_CONTEXT=2592000    # 30 days
REDIS_TTL_EPISODIC_CACHE=86400   # 24 hours

# ChromaDB (Semantic memory)
CHROMADB_HOST=localhost
CHROMADB_PORT=8200
CHROMADB_COLLECTION_GUIDELINES=clinical_guidelines
CHROMADB_COLLECTION_DRUGS=drug_knowledge
CHROMADB_PERSIST_DIR=data/chromadb

# LLM Router
LLM_PRIMARY_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_TIMEOUT=300

# OpenAI-compatible provider (vLLM, TGI, LiteLLM, etc.)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=dummy
OPENAI_COMPAT_MODEL=meta-llama/Llama-3.2-3B-Instruct
OPENAI_COMPAT_TIMEOUT=120

# LLM generation defaults
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.9

# Agent configuration
AGENT_MAX_REACT_ITERATIONS=5
AGENT_WORKING_MEMORY_MAX_STEPS=20
AGENT_CHAT_HISTORY_WINDOW=20

# Extraction Agent
EXTRACTION_TIMEOUT=60
EXTRACTION_RETRY_ATTEMPTS=3

# Reconciliation Agent
RECONCILIATION_FUZZY_THRESHOLD=0.85
RECONCILIATION_FILL_GAP_THRESHOLD_DAYS=7

# Clinical Reasoning Agent
CLINICAL_URGENCY_MAX_SCORE=10.0
CLINICAL_TIME_DECAY_FACTOR=0.1

# Drug databases
RXNORM_API_URL=https://rxnav.nlm.nih.gov/REST
OPENFDA_API_URL=https://api.fda.gov/drug
DRUG_API_TIMEOUT=10

